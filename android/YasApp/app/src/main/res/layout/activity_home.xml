<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9F7F4"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="56dp"
    android:paddingBottom="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="48dp"
        android:gravity="bottom">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YAS"
                android:textColor="#A78BFA"
                android:textSize="40sp"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="your daily word"
                android:textColor="#A78BFA"
                android:textSize="16sp"
                android:letterSpacing="0.04"
                android:textAllCaps="true"
                android:alpha="0.6" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/tvIdioma"
                android:layout_width="48dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="EN"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/pill_idioma"
                android:onClick="onIdiomaClick"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4B4A4A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDiaSemana"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#9CA3AF"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Loading -->
    <TextView
        android:id="@+id/tvLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="carregando..."
        android:textColor="#A78BFA"
        android:textSize="18sp" />

    <!-- Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPalavra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/circle_badge"
                    android:contentDescription="dot" />

                <TextView
                    android:id="@+id/tvBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="today's word"
                    android:textColor="#A78BFA"
                    android:textSize="16sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPalavra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2D2B2B"
                android:textSize="38sp"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFonetica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="18sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvDefinicao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#4B4A4A"
                android:textSize="18sp"
                android:lineSpacingExtra="6dp" />

            <TextView
                android:id="@+id/tvExemplo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#C4B5FD"
                android:textSize="17sp"
                android:fontStyle="italic"
                android:layout_marginTop="8dp" />

            <!-- Divider + Actions -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F3EFE8"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/btnListen"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="🔊  Listen"
                    android:textColor="#6B7280"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="#F9F7F4"
                    android:onClick="onListenClick"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnFavorito"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="♡  Save"
                    android:textColor="#A78BFA"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="#F9F7F4"
                    android:onClick="onFavoriteClick"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnShare"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="📤  Share"
                    android:textColor="#6B7280"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="#F9F7F4"
                    android:onClick="onShareClick"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginHorizontal="-24dp"
        android:paddingHorizontal="24dp"
        android:gravity="center">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="◉  Home"
            android:textColor="#A78BFA"
            android:textSize="16sp"
            android:gravity="center"
            android:onClick="onNavHomeClick"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⌕  Search"
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            android:gravity="center"
            android:onClick="onNavSearchClick"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navSaved"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="♡  Saved"
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            android:gravity="center"
            android:onClick="onNavSavedClick"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>