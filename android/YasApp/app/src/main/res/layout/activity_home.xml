<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9F7F4"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="56dp"
        android:gravity="bottom">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YAS"
                android:textColor="#A78BFA"
                android:textSize="32sp"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="your daily word"
                android:textColor="#A78BFA"
                android:textSize="10sp"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                android:alpha="0.6" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#4B4A4A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDiaSemana"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading -->
    <TextView
        android:id="@+id/tvLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="carregando..."
        android:textColor="#A78BFA"
        android:textSize="16sp" />

    <!-- Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPalavra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/circle_badge"
                    android:contentDescription="dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="today's word"
                    android:textColor="#A78BFA"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPalavra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2D2B2B"
                android:textSize="36sp"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFonetica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvDefinicao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#4B4A4A"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

            <TextView
                android:id="@+id/tvExemplo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#C4B5FD"
                android:textSize="14sp"
                android:fontStyle="italic"
                android:layout_marginTop="8dp" />

            <!-- Divider + Actions -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F3EFE8"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🔊  Listen"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:background="#F9F7F4"
                    android:onClick="onListenClick"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btnFavorito"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="♡  Save"
                    android:textColor="#A78BFA"
                    android:textSize="13sp"
                    android:background="#F9F7F4"
                    android:onClick="onFavoriteClick"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📤  Share"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:background="#F9F7F4"
                    android:onClick="onShareClick"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginHorizontal="-24dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="◉  Home"
            android:textColor="#A78BFA"
            android:textSize="11sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⌕  Search"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="♡  Saved"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>